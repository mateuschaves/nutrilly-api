generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String?
  name          String
  google_id     String?  @unique
  apple_id      String?  @unique
  created_at    DateTime @default(now())

  goals          UserGoal?
  meals          Meal[]
  waterLogs      WaterLog[]
  dailySummaries DailySummary[]
  streak         Streak?
  suspiciousPhotos SuspiciousPhoto[]

  @@map("users")
}

model UserGoal {
  id            String @id @default(uuid())
  user_id       String @unique
  calories_goal Float
  protein_goal  Float
  carbs_goal    Float
  fat_goal      Float
  water_goal_ml Float
  energy_unit   String @default("kcal")
  water_unit    String @default("l")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

model Food {
  id                String @id @default(uuid())
  name              String
  calories_per_100g Float
  protein_per_100g  Float
  carbs_per_100g    Float
  fat_per_100g      Float

  mealItems MealItem[]

  @@map("foods")
}

model Meal {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  photo_url  String?
  eaten_at   DateTime @default(now())
  created_at DateTime @default(now())

  user  User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items MealItem[]

  @@map("meals")
}

model MealItem {
  id       String @id @default(uuid())
  meal_id  String
  food_id  String
  grams    Float
  calories Float
  protein  Float
  carbs    Float
  fat      Float

  meal Meal @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  food Food @relation(fields: [food_id], references: [id])

  @@map("meal_items")
}

model WaterLog {
  id        String   @id @default(uuid())
  user_id   String
  amount_ml Float
  logged_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("water_logs")
}

model DailySummary {
  id       String   @id @default(uuid())
  user_id  String
  date     DateTime @db.Date
  calories Float    @default(0)
  protein  Float    @default(0)
  carbs    Float    @default(0)
  fat      Float    @default(0)
  water_ml Float    @default(0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date])
  @@map("daily_summaries")
}

model Streak {
  id                 String    @id @default(uuid())
  user_id            String    @unique
  current_streak     Int       @default(0)
  best_streak        Int       @default(0)
  last_goal_hit_date DateTime? @db.Date

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model SuspiciousPhoto {
  id          String   @id @default(uuid())
  user_id     String
  reason      String
  categories  String
  flagged_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("suspicious_photos")
}
