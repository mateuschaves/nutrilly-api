generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  email            String               @unique
  name             String
  passwordHash     String?
  googleId         String?              @unique
  appleId          String?              @unique
  unitPreferences  UserUnitPreferences?
  profile          UserProfile?
  meals              Meal[]
  diaryEntries       DiaryEntry[]
  mealAnalysisLogs   MealAnalysisLog[]
  hydrationEntries   HydrationEntry[]
  weightLogs       WeightLog[]
  achievements     UserAchievement[]
  tournamentMemberships  TournamentMember[]
  tournamentActivities   TournamentActivity[]
  devicePushTokens DevicePushToken[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@map("users")
}

model UserUnitPreferences {
  userId String @id @map("_id") @db.ObjectId
  energy String @default("kcal") // "kcal" | "kj"
  water  String @default("l")    // "l" | "fl_oz"
  weight String @default("kg")   // "kg" | "lbs"
  height String @default("cm")   // "cm" | "ft_in"

  user User @relation(fields: [userId], references: [id])

  @@map("user_unit_preferences")
}

model UserProfile {
  userId        String  @id @map("_id") @db.ObjectId
  birthdate     String? // YYYY-MM-DD
  sex           String? // "male" | "female"
  weightKg      Float?
  heightCm      Float?
  goal          String? // "lose_weight" | "maintain" | "gain_muscle"
  activityLevel String? // "sedentary" | "lightly_active" | "active" | "very_active"
  caloriesGoal  Int     @default(2200) // always kcal internally
  proteinGoalG  Float   @default(150)
  carbsGoalG    Float   @default(250)
  fatGoalG      Float   @default(70)
  waterGoalMl   Int     @default(2600) // always ml internally

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model Meal {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       @db.ObjectId
  name         String
  icon         String
  sortOrder    Int          @default(0)
  diaryEntries DiaryEntry[]

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("meals")
}

model DiaryEntry {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  mealId   String   @db.ObjectId
  date     String   // YYYY-MM-DD
  name     String
  kcal     Int
  proteinG Float
  carbsG   Float
  fatG     Float
  portion  String
  photoUri String?
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  meal Meal @relation(fields: [mealId], references: [id])

  @@index([userId, date])
  @@map("diary_entries")
}

model MealAnalysisLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  sessionId  String   // groups an ANALYZE + its subsequent CORRECTs
  type       String   // "ANALYZE" | "CORRECT"
  correction String?  // the correction instruction (only for CORRECT)
  result     Json     // FoodAnalysis result
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@map("meal_analysis_logs")
}

model HydrationEntry {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  date     String   // YYYY-MM-DD
  amountMl Int
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("hydration_entries")
}

model WeightLog {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  weightKg Float
  source   String   // WeightSource enum: "APPLE_HEALTH" | "SAMSUNG_HEALTH" | "GOOGLE_FIT" | "MANUAL"
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, loggedAt])
  @@map("weight_logs")
}

model UserAchievement {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  achievementKey String
  earnedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, achievementKey])
  @@map("user_achievements")
}

// ─── Devices ────────────────────────────────────────────────────────────────

model DevicePushToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("device_push_tokens")
}

// ─── Tournaments ────────────────────────────────────────────────────────────

model Tournament {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  bannerUri   String?
  inviteCode  String    @unique
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("UPCOMING") // UPCOMING | ACTIVE | ENDED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scoreLimitEnabled Boolean @default(false)
  scoreLimitMaxPts  Int     @default(200)
  scoreLimitPeriod  String  @default("DAY") // DAY | WEEK | MONTH

  members      TournamentMember[]
  activities   TournamentActivity[]
  scoringRules TournamentScoringRule[]

  @@map("tournaments")
}

model TournamentMember {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String   @db.ObjectId
  userId       String   @db.ObjectId
  role         String   @default("MEMBER") // MEMBER | ADMIN
  points       Int      @default(0)
  position     Int      @default(0)
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@map("tournament_members")
}

model TournamentScoringRule {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String   @db.ObjectId
  type         String   // ScoringRuleType: MEAL_LOGGED | HEALTHY_MEAL | UNHEALTHY_MEAL | DAILY_GOAL_MET | WATER_GOAL_MET | CALORIES_BURNED | WEIGHT_LOSS
  label        String
  description  String
  points       Int
  enabled      Boolean  @default(true)
  unit         String?
  emoji        String

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, type])
  @@map("tournament_scoring_rules")
}

model TournamentActivity {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId   String   @db.ObjectId
  userId         String   @db.ObjectId
  type           String   // ScoringRuleType
  label          String
  points         Int
  emoji          String
  date           String   // YYYY-MM-DD
  time           String   // HH:MM
  calories       Float?
  mealName       String?
  weightKg       Float?
  caloriesBurned Float?
  waterLiters    Float?
  protein        Float?
  carbs          Float?
  fat            Float?
  createdAt      DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@index([tournamentId, createdAt])
  @@map("tournament_activities")
}
